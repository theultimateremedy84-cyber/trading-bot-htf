# ============================================================
# ICT Trading Bot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=5000
NODE_ENV=production
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# Capital.com API credentials
# Get these from https://capital.com → Settings → API Access
CAPITAL_API_KEY=your-capital-com-api-key
CAPITAL_IDENTIFIER=your-email@example.com
CAPITAL_PASSWORD=your-capital-com-password

# API base URL — use demo for testing, live for real money
# Demo:  https://demo-api-capital.backend.gbaaservice.com
# Live:  https://api-capital.backend.gbaaservice.com
CAPITAL_API_URL=https://demo-api-capital.backend.gbaaservice.com
